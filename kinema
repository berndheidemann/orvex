#!/usr/bin/env bash
# kinema — Unified entry point for the Kinema agent framework
# Usage: cd my-project && /path/to/kinema [init]
set -euo pipefail

FRAMEWORK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOOP_SCRIPT="$FRAMEWORK_DIR/loop_dev.sh"
TUI_BIN="$FRAMEWORK_DIR/kinema-tui"
TEMPLATES_DIR="$FRAMEWORK_DIR/templates"

# ── Init-Logik (shared zwischen 'kinema init' und leerem Ordner) ─
do_init() {
  for f in AGENT.md VALIDATOR.md; do
    if [ -f "$f" ]; then
      echo "⏭  $f existiert bereits — übersprungen"
    else
      cp "$TEMPLATES_DIR/$f" "./$f"
      echo "✅  $f erstellt"
    fi
  done

  mkdir -p .agent

  # Launch TUI in init mode — user enters description and round counts there
  KINEMA_INIT_MODE=1 \
  KINEMA_AGENT_DIR="$(pwd)/.agent" \
  "$TUI_BIN"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  ⚠️   Bitte vor dem ersten Start sorgfältig prüfen:"
  echo ""
  echo "  PRD.md"
  echo "    • Alle wichtigen Features enthalten?"
  echo "    • Akzeptanzkriterien präzise und testbar?"
  echo "    • User Journeys vollständig?"
  echo "    • Priorisierung korrekt?  (P0 = MVP-Blocker · P1 = wichtig · P2 = nice-to-have)"
  echo ""
  if [ -f .agent/architecture.md ] && grep -q 'ADR-' .agent/architecture.md 2>/dev/null; then
    echo "  .agent/architecture.md"
    echo "    • Tech-Stack passend für das Projekt?"
    echo "    • Architektur-Pattern verständlich?"
    echo "    • Projektstruktur sinnvoll?"
    echo ""
  fi
  echo "  KI-Entwürfe sind ein erster Aufschlag —"
  echo "  kein Ersatz für dein Domänenwissen."
  echo ""
  echo "  Wenn alles bereit ist: kinema erneut starten"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  exit 0
}

# ── kinema init ───────────────────────────────────────────────
if [ "${1:-}" = "init" ]; then
  echo "Kinema — Projekt initialisieren"
  echo ""
  do_init
fi

# ── Validation ────────────────────────────────────────────────
errors=0

for f in PRD.md AGENT.md VALIDATOR.md; do
  if [ ! -f "$f" ] && [ ! -L "$f" ]; then
    echo "❌  $f fehlt in $(pwd)"
    errors=$((errors + 1))
  fi
done

if [ -f PRD.md ] && ! grep -q '^### REQ-' PRD.md 2>/dev/null; then
  echo "❌  PRD.md enthält keine Requirements (erwartet: '### REQ-XXX:')"
  errors=$((errors + 1))
fi

if [ $errors -gt 0 ]; then
  echo ""
  printf "Projekt initialisieren? [j/N] "
  read -r answer
  if [ "$answer" = "j" ] || [ "$answer" = "J" ] || \
     [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
    echo ""
    do_init
  else
    exit 1
  fi
fi

# ── Setup ─────────────────────────────────────────────────────
mkdir -p .agent/logs

if [ -f .agent/status.json ]; then
  req_count=$(jq 'length' .agent/status.json 2>/dev/null || echo "0")
  if [ "$req_count" = "0" ]; then
    rm .agent/status.json
  fi
fi

export KINEMA_AGENT_DIR="$(pwd)/.agent"
export KINEMA_TUI=1

# ── Loop im Hintergrund starten ────────────────────────────────
LOOP_LOG=".agent/logs/loop.log"
"$LOOP_SCRIPT" >"$LOOP_LOG" 2>&1 &
LOOP_PID=$!

cleanup() {
  kill "$LOOP_PID" 2>/dev/null || true
  wait "$LOOP_PID" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

sleep 1
if ! kill -0 "$LOOP_PID" 2>/dev/null; then
  echo "❌  loop_dev.sh ist sofort beendet. Ausgabe:"
  echo ""
  tail -20 "$LOOP_LOG"
  exit 1
fi

# ── TUI im Vordergrund ────────────────────────────────────────
KINEMA_AGENT_DIR="$(pwd)/.agent" "$TUI_BIN"
