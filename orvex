#!/usr/bin/env bash
# orvex — Unified entry point for the Orvex agent framework
# Usage: cd my-project && /path/to/orvex [init]
set -euo pipefail

# Resolve symlinks so the framework dir is always the repo root,
# even when orvex is invoked via a symlink in /usr/local/bin.
_SELF="${BASH_SOURCE[0]}"
while [ -L "$_SELF" ]; do _SELF="$(readlink "$_SELF")"; done
FRAMEWORK_DIR="$(cd "$(dirname "$_SELF")" && pwd)"
unset _SELF
LOOP_SCRIPT="$FRAMEWORK_DIR/loop_dev.sh"
TUI_BIN="$FRAMEWORK_DIR/orvex-tui"
TEMPLATES_DIR="$FRAMEWORK_DIR/templates"

# ── Post-init scaffolding ─────────────────────────────────────
# Copies template files, initializes git, and creates initial commit
# after init or edu-init. Safe to call multiple times — all steps are
# guarded by existence checks.
post_init_scaffold() {
  # Only run if PRD.md was generated (init succeeded)
  [ -f PRD.md ] || return 0

  # Copy template files (skip if already present — user may have customized)
  for f in AGENT.md VALIDATOR.md REFACTOR.md REFACTOR_TEMPLATE.md; do
    if [ ! -f "$f" ] && [ -f "$TEMPLATES_DIR/$f" ]; then
      cp "$TEMPLATES_DIR/$f" "$f"
      echo "  ✅  $f"
    fi
  done

  # Init git repo if none exists
  if ! git rev-parse --git-dir >/dev/null 2>&1; then
    git init -q
    echo "  ✅  git init"
  fi

  # Initial commit if no commits yet
  if ! git rev-parse HEAD >/dev/null 2>&1; then
    git add -A
    git commit -q -m "chore: orvex init — PRD + architecture"
    echo "  ✅  Initial commit"
  fi
}

# ── Edu-Init logic ────────────────────────────────────────────
do_edu_init() {
  if ! git -C . rev-parse --git-dir > /dev/null 2>&1; then
    echo "  Git-Repository nicht gefunden — initialisiere mit git init..."
    git init
  fi

  mkdir -p .agent

  ORVEX_AGENT_DIR="$(pwd)/.agent" \
  "$TUI_BIN" --edu-init

  post_init_scaffold

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  ⚠️   Bitte vor dem ersten Start sorgfältig prüfen:"
  echo ""
  echo "  LERNSITUATION.md"
  echo "    • Lernziele vollständig und klar formuliert?"
  echo "    • Lernphasen und Zeitplanung realistisch?"
  echo "    • Differenzierungsmaßnahmen passend?"
  echo ""
  echo "  PRD.md"
  echo "    • Alle wichtigen Features erfasst?"
  echo "    • Akzeptanzkriterien präzise und testbar?"
  echo "    • Prioritäten korrekt?  (P0 = MVP · P1 = wichtig · P2 = nice-to-have)"
  echo ""
  if [ -f architecture.md ] && grep -q 'ADR-' architecture.md 2>/dev/null; then
    echo "  architecture.md"
    echo "    • Tech-Stack für das Projekt geeignet?"
    echo "    • Architektur-Entscheidungen nachvollziehbar?"
    echo "    • Projektstruktur sinnvoll?"
    echo ""
  fi
  echo "  KI-Entwürfe sind ein Ausgangspunkt —"
  echo "  kein Ersatz für eigenes Domänenwissen."
  echo ""
  echo "  Wenn bereit: orvex erneut aufrufen"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  exit 0
}

# ── Init logic (shared between 'orvex init' and empty folder) ────
do_init() {
  for f in AGENT.md VALIDATOR.md REFACTOR.md; do
    if [ -f "$f" ]; then
      echo "⏭  $f already exists — skipped"
    else
      cp "$TEMPLATES_DIR/$f" "./$f"
      echo "✅  $f created"
    fi
  done

  mkdir -p .agent

  # Launch TUI in init mode — user enters description and round counts there
  ORVEX_INIT_MODE=1 \
  ORVEX_AGENT_DIR="$(pwd)/.agent" \
  "$TUI_BIN"

  post_init_scaffold

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  ⚠️   Please review carefully before the first run:"
  echo ""
  echo "  PRD.md"
  echo "    • All important features included?"
  echo "    • Acceptance criteria precise and testable?"
  echo "    • User journeys complete?"
  echo "    • Priorities correct?  (P0 = MVP blocker · P1 = important · P2 = nice-to-have)"
  echo ""
  if [ -f architecture.md ] && grep -q 'ADR-' architecture.md 2>/dev/null; then
    echo "  architecture.md"
    echo "    • Tech stack appropriate for the project?"
    echo "    • Architecture patterns clear?"
    echo "    • Project structure sensible?"
    echo ""
  fi
  echo "  AI drafts are a starting point —"
  echo "  not a substitute for your domain knowledge."
  echo ""
  echo "  When ready: run orvex again"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  exit 0
}

# ── orvex help ────────────────────────────────────────────────
if [ "${1:-}" = "help" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  cat <<'EOF'
Orvex — AI-driven development loop

USAGE
  orvex                 Start (or resume) the agent loop in the current project
  orvex init            Create PRD.md / architecture.md interactively, then start
  orvex edu-init        Create a didactic learning situation (LERNSITUATION.md)
  orvex help            Show this help

DASHBOARD KEYS
  p          Pause / resume the agent loop
  s          Skip the current iteration
  e          Edit context.md (agent instructions)
  r          Toggle requirement-focus mode
  q          Quit — loop is stopped gracefully

REQUIREMENT FOCUS MODE  (press r)
  ↑ / ↓      Navigate the requirement list
  Tab        Switch focus between list and detail pane
  ↑ / ↓      Scroll the detail pane (when focused)

PROJECT FILES
  PRD.md          Requirements the agent works through
  AGENT.md        Persistent instructions for the agent
  VALIDATOR.md    Acceptance-test script run after each iteration
  architecture.md Tech-stack and project-structure decisions
  .agent/         Runtime state (status, logs, events)

WORKFLOW
  1. orvex init          — set up a new project
  2. Review PRD.md       — adjust priorities and acceptance criteria
  3. orvex               — start the loop; agent implements REQs one by one
  4. Press q to stop     — resume any time with: orvex

EOF
  exit 0
fi

# ── orvex init ────────────────────────────────────────────────
if [ "${1:-}" = "init" ]; then
  echo "Orvex — Initialize project"
  echo ""
  do_init
fi

# ── orvex edu-init ────────────────────────────────────────────
if [ "${1:-}" = "edu-init" ]; then
  do_edu_init
fi

# ── Validation ────────────────────────────────────────────────
errors=0

for f in PRD.md AGENT.md VALIDATOR.md; do
  if [ ! -f "$f" ] && [ ! -L "$f" ]; then
    echo "❌  $f missing in $(pwd)"
    errors=$((errors + 1))
  fi
done

if [ -f PRD.md ] && ! grep -qE '^### (REQ|CONT)-' PRD.md 2>/dev/null; then
  echo "❌  PRD.md contains no requirements (expected: '### REQ-XXX:' or '### CONT-XXX:')"
  errors=$((errors + 1))
fi

if [ $errors -gt 0 ]; then
  echo ""
  printf "Initialize project? [y/N] "
  read -r answer
  if [ "$answer" = "j" ] || [ "$answer" = "J" ] || \
     [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
    echo ""
    do_init
  else
    exit 1
  fi
fi

# ── Setup ─────────────────────────────────────────────────────
mkdir -p .agent/logs

if [ -f .agent/status.json ]; then
  req_count=$(jq 'length' .agent/status.json 2>/dev/null || echo "0")
  if [ "$req_count" = "0" ]; then
    rm .agent/status.json
  fi
fi

export ORVEX_AGENT_DIR="$(pwd)/.agent"
export ORVEX_TUI=1

# ── Start loop in background ──────────────────────────────────
LOOP_LOG=".agent/logs/loop.log"
"$LOOP_SCRIPT" >"$LOOP_LOG" 2>&1 &
LOOP_PID=$!

cleanup() {
  kill "$LOOP_PID" 2>/dev/null || true
  # Poll instead of blocking wait — avoids hanging when the TUI already
  # sent SIGTERM and the loop is still finishing its own cleanup.
  local i=0
  while kill -0 "$LOOP_PID" 2>/dev/null && [ $i -lt 25 ]; do
    sleep 0.2
    i=$((i+1))
  done
  # Force-kill if still alive after 5 s
  kill -9 "$LOOP_PID" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

sleep 1
if ! kill -0 "$LOOP_PID" 2>/dev/null; then
  echo "❌  loop_dev.sh exited immediately. Output:"
  echo ""
  tail -20 "$LOOP_LOG"
  exit 1
fi

# ── Launch TUI in foreground ──────────────────────────────────
ORVEX_AGENT_DIR="$(pwd)/.agent" "$TUI_BIN"
