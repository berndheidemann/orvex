#!/usr/bin/env bash
# orvex — Unified entry point for the Orvex agent framework
# Usage: cd my-project && /path/to/orvex [init]
set -euo pipefail

# Resolve symlinks so the framework dir is always the repo root,
# even when orvex is invoked via a symlink in /usr/local/bin.
_SELF="${BASH_SOURCE[0]}"
while [ -L "$_SELF" ]; do _SELF="$(readlink "$_SELF")"; done
FRAMEWORK_DIR="$(cd "$(dirname "$_SELF")" && pwd)"
unset _SELF
LOOP_SCRIPT="$FRAMEWORK_DIR/loop_dev.sh"
TUI_BIN="$FRAMEWORK_DIR/orvex-tui"
TEMPLATES_DIR="$FRAMEWORK_DIR/templates"

# ── Edu-Init logic ────────────────────────────────────────────
do_edu_init() {
  if ! git -C . rev-parse --git-dir > /dev/null 2>&1; then
    echo "❌  Not a git repository. Please run 'orvex edu-init' from a git repo."
    exit 1
  fi

  mkdir -p .agent

  ORVEX_AGENT_DIR="$(pwd)/.agent" \
  "$TUI_BIN" --edu-init

  exit 0
}

# ── Init logic (shared between 'orvex init' and empty folder) ────
do_init() {
  for f in AGENT.md VALIDATOR.md REFACTOR.md; do
    if [ -f "$f" ]; then
      echo "⏭  $f already exists — skipped"
    else
      cp "$TEMPLATES_DIR/$f" "./$f"
      echo "✅  $f created"
    fi
  done

  mkdir -p .agent

  # Launch TUI in init mode — user enters description and round counts there
  ORVEX_INIT_MODE=1 \
  ORVEX_AGENT_DIR="$(pwd)/.agent" \
  "$TUI_BIN"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "  ⚠️   Please review carefully before the first run:"
  echo ""
  echo "  PRD.md"
  echo "    • All important features included?"
  echo "    • Acceptance criteria precise and testable?"
  echo "    • User journeys complete?"
  echo "    • Priorities correct?  (P0 = MVP blocker · P1 = important · P2 = nice-to-have)"
  echo ""
  if [ -f architecture.md ] && grep -q 'ADR-' architecture.md 2>/dev/null; then
    echo "  architecture.md"
    echo "    • Tech stack appropriate for the project?"
    echo "    • Architecture patterns clear?"
    echo "    • Project structure sensible?"
    echo ""
  fi
  echo "  AI drafts are a starting point —"
  echo "  not a substitute for your domain knowledge."
  echo ""
  echo "  When ready: run orvex again"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  exit 0
}

# ── orvex init ────────────────────────────────────────────────
if [ "${1:-}" = "init" ]; then
  echo "Orvex — Initialize project"
  echo ""
  do_init
fi

# ── orvex edu-init ────────────────────────────────────────────
if [ "${1:-}" = "edu-init" ]; then
  do_edu_init
fi

# ── Validation ────────────────────────────────────────────────
errors=0

for f in PRD.md AGENT.md VALIDATOR.md; do
  if [ ! -f "$f" ] && [ ! -L "$f" ]; then
    echo "❌  $f missing in $(pwd)"
    errors=$((errors + 1))
  fi
done

if [ -f PRD.md ] && ! grep -q '^### REQ-' PRD.md 2>/dev/null; then
  echo "❌  PRD.md contains no requirements (expected: '### REQ-XXX:')"
  errors=$((errors + 1))
fi

if [ $errors -gt 0 ]; then
  echo ""
  printf "Initialize project? [y/N] "
  read -r answer
  if [ "$answer" = "j" ] || [ "$answer" = "J" ] || \
     [ "$answer" = "y" ] || [ "$answer" = "Y" ]; then
    echo ""
    do_init
  else
    exit 1
  fi
fi

# ── Setup ─────────────────────────────────────────────────────
mkdir -p .agent/logs

if [ -f .agent/status.json ]; then
  req_count=$(jq 'length' .agent/status.json 2>/dev/null || echo "0")
  if [ "$req_count" = "0" ]; then
    rm .agent/status.json
  fi
fi

export ORVEX_AGENT_DIR="$(pwd)/.agent"
export ORVEX_TUI=1

# ── Start loop in background ──────────────────────────────────
LOOP_LOG=".agent/logs/loop.log"
"$LOOP_SCRIPT" >"$LOOP_LOG" 2>&1 &
LOOP_PID=$!

cleanup() {
  kill "$LOOP_PID" 2>/dev/null || true
  wait "$LOOP_PID" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

sleep 1
if ! kill -0 "$LOOP_PID" 2>/dev/null; then
  echo "❌  loop_dev.sh exited immediately. Output:"
  echo ""
  tail -20 "$LOOP_LOG"
  exit 1
fi

# ── Launch TUI in foreground ──────────────────────────────────
ORVEX_AGENT_DIR="$(pwd)/.agent" "$TUI_BIN"
